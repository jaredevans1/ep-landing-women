---
import Layout from "@/layouts/Layout.astro";
import NavigationHeader from "@/components/NavigationHeader.astro";
import HeroSection from "@/components/HeroSection.astro";
import DifferentiationSection from "@/components/DifferentiationSection.astro";
import RealitySection from "@/components/RealitySection.astro";
import PillarsSection from "@/components/PillarsSection.astro";
import DashboardPreviewSection from "@/components/DashboardPreviewSection.astro";
import PortalPreviewSection from "@/components/PortalPreviewSection.astro";
import CaseStudiesSection from "@/components/CaseStudiesSection.astro";
import JourneySection from "@/components/JourneySection.astro";
import TeamSection from "@/components/TeamSection.astro";
import QualifierSection from "@/components/QualifierSection.astro";
import InvestmentSection from "@/components/InvestmentSection.astro";
import SuccessStoriesSection from "@/components/SuccessStoriesSection.astro";
import FAQSection from "@/components/FAQSection.astro";
import CTASection from "@/components/CTASection.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <NavigationHeader />
  <main class="min-h-screen">
    <HeroSection />
    <!-- Divider between hero and content -->
    <div class="relative py-2">
      <div class="h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
    </div>
    <DifferentiationSection />
    <RealitySection />
    <PillarsSection />
    <CaseStudiesSection />
    <div class="relative py-2">
      <div class="h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
    </div>
    <PortalPreviewSection />
    <SuccessStoriesSection />
    <DashboardPreviewSection />
    <JourneySection />
    <TeamSection />
    <QualifierSection />
    <InvestmentSection />
    <FAQSection />
    <CTASection />
  </main>
  <Footer />
</Layout>
