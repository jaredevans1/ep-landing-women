---
import portalImg from "@/assets/portal/portal-screenshot.png";
---

<section class="py-16 md:py-28 bg-background overflow-hidden">
  <div class="container px-4">
    <div class="text-center max-w-3xl mx-auto mb-14">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-4 block">Your Precision Health Portal</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Every Data Point. <span class="text-gradient">One System.</span>
      </h2>
      <p class="text-muted-foreground">
        Biomarkers, nutrition, training, recovery, and coaching insights. All connected,
        all visible, all driving your protocols in real time.
      </p>
    </div>

    <div class="max-w-5xl mx-auto mb-6">
      <div class="rounded-xl overflow-hidden border-2 border-primary/40 shadow-[0_0_80px_hsl(var(--primary)/0.4),0_0_40px_hsl(var(--primary)/0.25),0_0_15px_hsl(var(--primary)/0.15)] p-3 bg-card">
        <img
          src={portalImg.src}
          alt="Precision health portal showing Total Health Score, biomarker analysis, and system performance metrics"
          loading="lazy"
          class="w-full h-auto block rounded-lg"
          width={portalImg.width}
          height={portalImg.height}
        />
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 max-w-4xl mx-auto mt-8 sm:mt-12">
      {["55 Biomarkers Scored", "Coaching Insights", "Live Wearable Sync", "Monthly Scorecards"].map((label) => (
        <div class="flex items-center justify-center gap-1.5 sm:gap-2 px-3 sm:px-4 py-2.5 sm:py-3 rounded-lg bg-card border border-border text-center">
          <div class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></div>
          <span class="text-xs sm:text-sm text-muted-foreground font-medium">{label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
