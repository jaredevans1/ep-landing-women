---
import { Image } from "astro:assets";
import emilyImg from "@/assets/team/emily.jpg";
import jaredImg from "@/assets/team/jared.jpg";

const teamMembers = [
  {
    name: "Emily Evans",
    credentials: "MA. BSc. NASM-CNC",
    image: emilyImg,
    education: [
      "MA. Speech Communication Sciences",
      "BSc. Speech Pathology",
      "Certified Nutrition Coach"
    ],
    certifications: [
      "Former Cleveland Clinic Pediatric ICU Therapist",
      "7+ Years Coaching & Therapy Experience"
    ]
  },
  {
    name: "Jared Evans",
    credentials: "BSc. NASM-CPT, CNC",
    image: jaredImg,
    education: [
      "M.Eng Master of Engineering",
      "BSc. Molecular Neuroscience",
      "AAS. Electrical Engineering"
    ],
    certifications: [
      "Certified Personal Trainer",
      "Certified Nutrition Coach",
      "Ironman Coach/Athlete",
      "10+ Years Coaching Experience"
    ]
  }
];
---

<section id="team" class="py-20 md:py-32 bg-background">
  <div class="container px-4">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-4 block">
        Meet Your Team
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        Your Performance Team
      </h2>
      <p class="text-lg text-muted-foreground">
        40+ years of combined experience in engineering elite human performance.
      </p>
    </div>

    <!-- Team grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
      {teamMembers.map((member) => (
        <div class="overflow-hidden bg-white rounded-lg border border-border group hover:border-primary/50 transition-colors shadow-sm">
          <!-- Image -->
          <div class="aspect-[4/5] overflow-hidden">
            <Image
              src={member.image}
              alt={member.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>

          <!-- Content -->
          <div class="p-6">
            <h3 class="text-xl font-bold text-foreground">{member.name}</h3>
            <p class="text-primary text-sm font-medium mb-4">{member.credentials}</p>

            <div class="space-y-3">
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wide mb-2">Education</p>
                <ul class="space-y-1">
                  {member.education.map((item) => (
                    <li class="text-sm text-muted-foreground">{item}</li>
                  ))}
                </ul>
              </div>

              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wide mb-2">Experience</p>
                <ul class="space-y-1">
                  {member.certifications.map((item) => (
                    <li class="text-sm text-muted-foreground">{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
