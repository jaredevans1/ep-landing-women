---
const testimonials = [
  {
    name: "Linda Theisen",
    title: "VP, Hilton Supply Management",
    quote: "I have been working with Jared and Emily for the past 7 weeks. From day one, I knew this approach was different. They truly understand the unique challenges of executive life - the travel, the stress, the endless demands. The comprehensive blood work they provide is truly game-changing.",
    isLinkedIn: true
  },
  {
    name: "Carrie P.",
    title: "Nurse & Mom of 4",
    quote: "As the wife of an executive, busy mom of 4 student athletes, and a nurse, I like to make sure everyone is on time, has what they need, and stays on track. Emily and Jared were just what I needed at this point in my life. They thoroughly listened from day 1 and made changes throughout the program based on how I felt or what I needed. I appreciate that they are data driven, and truly had the knowledge about the program they were creating for me.",
    isLinkedIn: false
  },
  {
    name: "Maryam T.",
    title: "Client",
    quote: "Working with Emily has been truly transformative. She's helped me build healthier eating habits that actually feel sustainable, not restrictive. I've noticed a big difference in my energy, strength, and confidence. Her guidance, support, and accountability have made it easier to stay consistent. What I've gained mentally has been priceless. I've never felt this supported before and I've had different coaches throughout the years.",
    isLinkedIn: false
  },
];
---

<section class="py-12 md:py-20 bg-background">
  <div class="container px-4">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-10">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-3 block">
        Client Testimonials
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        What Our Clients Are Saying
      </h2>
      <p class="text-muted-foreground">
        Real results from real women. See what our clients have achieved.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <div class="p-5 bg-white rounded-lg border border-border hover:border-primary/30 transition-colors flex flex-col min-h-[200px] shadow-sm">
          <blockquote class="text-sm text-foreground mb-4 leading-relaxed flex-1">
            "{t.quote}"
          </blockquote>
          <div>
            <p class="font-bold text-foreground text-sm flex items-center gap-2">
              {t.name}
              {t.isLinkedIn && (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0A66C2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              )}
            </p>
            <p class="text-xs text-muted-foreground">{t.title}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
