---
const forYouItems = [
  "You've been told \"it's stress\" or \"it's your age\" and you know that's not the full answer",
  "You're a professional woman who knows something is off and you're done guessing",
  "You're tired of generic advice from your doctor you can't actually do anything with. You want real answers and a plan you can execute.",
  "You want to know what's actually happening inside your body and you're ready to follow a system"
];

const notForYouItems = [
  "You want a meal plan and a workout PDF",
  "You're looking for a quick fix or a 30-day program",
  "You're not ready to invest in or execute on protocols",
  "You think \"normal\" lab ranges mean you're fine",
  "You're satisfied with the system you're using to manage your health and aging"
];
---

<section class="py-20 md:py-32 bg-white">
  <div class="container px-4">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-4 block">
        The Right Fit
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-foreground mb-6">
        This System Isn't For Everyone
      </h2>
      <p class="text-lg text-muted-foreground">
        Our system works best for women who are ready to commit to a holistic data-driven approach.
      </p>
    </div>

    <!-- Two column layout -->
    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- For You card -->
      <div class="p-8 rounded-2xl bg-green-50/60 border-2 border-green-300 shadow-[0_0_30px_rgba(34,197,94,0.1)]">
        <h3 class="text-xl font-bold text-foreground mb-6 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          This Is For You If:
        </h3>
        <ul class="space-y-4">
          {forYouItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-muted-foreground">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Not For You card -->
      <div class="p-8 rounded-2xl bg-red-50/60 border-2 border-red-300 shadow-[0_0_30px_rgba(239,68,68,0.1)]">
        <h3 class="text-xl font-bold text-foreground mb-6 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-500"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </div>
          This Is Not For You If:
        </h3>
        <ul class="space-y-4">
          {notForYouItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400 flex-shrink-0 mt-0.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              <span class="text-muted-foreground">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
