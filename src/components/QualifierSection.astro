---
const forYouItems = [
  "You're a busy woman who's ready to prioritize your health",
  "You're tired of fragmented solutions that don't talk to each other",
  "You want to understand what's actually happening inside your body",
  "You're looking for a sustainable system, not a quick fix"
];
---

<section class="py-20 md:py-32 bg-white">
  <div class="container px-4">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-4 block">
        Is This Right For You?
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        Built for Women Ready to Transform
      </h2>
      <p class="text-lg text-muted-foreground">
        Our system works best for women who are ready to commit to a data-driven approach.
      </p>
    </div>

    <!-- Single column - positive framing only -->
    <div class="max-w-2xl mx-auto">
      <div class="p-8 rounded-2xl bg-primary/5 border border-primary/20">
        <h3 class="text-xl font-bold text-foreground mb-6 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          This System Is For You If:
        </h3>
        <ul class="space-y-4">
          {forYouItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-muted-foreground">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
