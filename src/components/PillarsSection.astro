---
const pillars = [
  {
    title: "Biomarker Intelligence",
    description: "55 key biomarkers analyzed across metabolic, hormonal, thyroid, cardiovascular, and inflammatory systems.\n\nWe connect the dots between markers that are typically reviewed in isolation, so nothing gets missed.",
    color: "#22C55E",
    icon: "beaker"
  },
  {
    title: "Nutrition Architecture",
    description: "A flexible approach to eating that works with your life. Between work, kids, and everything else on your calendar, the last thing you need is a rigid meal plan.\n\nWe build strategies around what you already enjoy. Sustainable, doable, and built for your schedule.",
    color: "#F97316",
    icon: "utensils"
  },
  {
    title: "Training & Performance",
    description: "Two to three targeted sessions per week. Designed to optimize your hormonal landscape, preserve bone density, and protect against age-related muscle loss.\n\nNo hours in the gym. No endless cardio. Every session is programmed around your goals and your life stage.",
    color: "#3B82F6",
    icon: "dumbbell"
  },
  {
    title: "Sleep & Recovery",
    description: "We track HRV, sleep quality, and strain levels to know when to push and when to rest.\n\nOver time, you learn to read your body's cues and make better decisions about your energy every day.",
    color: "#A855F7",
    icon: "moon"
  },
  {
    title: "Coaching & Accountability",
    description: "Someone genuinely invested in your success. Someone who answers your questions thoroughly, holds you accountable without judgment, and cares about your goals as much as you do.\n\nWeekly check-ins and monthly scorecards keep you on track.",
    color: "#C8A65E",
    icon: "phone"
  },
  {
    title: "Data Integration",
    description: "Everything connected. Your labs and biometrics drive every protocol decision.\n\nAll of it available on your live dashboard, updated in real time.",
    color: "#06B6D4",
    icon: "database"
  }
];
---

<section id="system" class="py-12 md:py-20 bg-card relative overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-primary/5 rounded-full blur-[120px]"></div>

  <div class="container px-4 relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-10">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-3 block">
        The System
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        6 Pillars of Precision Health
      </h2>
      <p class="text-muted-foreground">
        We analyze what's actually happening inside your body, then build a system around it.
      </p>
      <p class="text-muted-foreground mt-1">
        One team. Nothing siloed.
      </p>
    </div>

    <!-- Pillars grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {pillars.map((pillar) => (
        <div class="group relative rounded-2xl bg-background border border-border hover:border-primary/40 transition-all duration-300 overflow-hidden border-l-4" style={`border-left-color: ${pillar.color}`}>
          <!-- Hover glow -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style={`background: radial-gradient(circle at 0% 50%, ${pillar.color}08 0%, transparent 70%)`}></div>
          <div class="p-6 relative">
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-5 border"
            style={`background-color: ${pillar.color}15; border-color: ${pillar.color}30`}
          >
            {pillar.icon === "beaker" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={pillar.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 3h15"/><path d="M6 3v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V3"/><path d="M6 14h12"/></svg>
            )}
            {pillar.icon === "utensils" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={pillar.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
            )}
            {pillar.icon === "dumbbell" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={pillar.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.4 14.4 9.6 9.6"/><path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767 1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l-1.768 1.767a2 2 0 1 1 2.828 2.829z"/><path d="m21.5 21.5-1.4-1.4"/><path d="M3.9 3.9 2.5 2.5"/><path d="M6.404 12.768a2 2 0 1 1-2.829-2.829l1.768-1.767a2 2 0 1 1-2.828-2.829l2.828-2.828a2 2 0 1 1 2.829 2.828l1.767-1.768a2 2 0 1 1 2.829 2.829z"/></svg>
            )}
            {pillar.icon === "moon" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={pillar.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            )}
            {pillar.icon === "phone" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={pillar.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            )}
            {pillar.icon === "database" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={pillar.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
            )}
          </div>
          <h3 class="text-lg font-bold mb-2 text-foreground">{pillar.title}</h3>
          <div class="text-sm text-muted-foreground leading-relaxed">
            {pillar.description.split('\n\n').map((paragraph) => (
              <p class="mb-2 last:mb-0">{paragraph}</p>
            ))}
          </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
