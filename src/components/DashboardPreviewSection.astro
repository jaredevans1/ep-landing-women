---
const metricBadges = [
  { value: "165.2", label: "lbs", color: "blue", icon: "scale" },
  { value: "-350", label: "deficit", color: "green", icon: "target" },
  { value: "150g", label: "protein", color: "orange", icon: "zap" },
];

const statBoxes = [
  { label: "Current Weight", value: "165.2", unit: "lbs", trend: "-0.8", trendColor: "green" },
  { label: "Body Fat", value: "27.4", unit: "%", trend: "-0.4", trendColor: "green" },
  { label: "Lean Mass", value: "119.9", unit: "lbs", trend: "+0.3", trendColor: "green" },
  { label: "BMR", value: "1,458", unit: "cal" },
];

const strategies = [
  { title: "Nutrition", status: "On Track", progress: 78, color: "#22C55E", icon: "apple", metrics: [{ label: "Calories", value: "1,740 / 1,900" }, { label: "Protein", value: "142g / 150g" }] },
  { title: "Training", status: "Active Phase", progress: 65, color: "#3B82F6", icon: "dumbbell", metrics: [{ label: "Sessions", value: "3 / 4" }, { label: "Volume", value: "14,200 lbs" }] },
  { title: "Recovery", status: "Optimal", progress: 92, color: "#A855F7", icon: "moon", metrics: [{ label: "Sleep Score", value: "87%" }, { label: "HRV", value: "55ms" }] },
];

const biomarkers = [
  { label: "Estradiol", value: "85", unit: "pg/mL", grade: "A", gradeColor: "#22C55E" },
  { label: "Cortisol", value: "12.4", unit: "ug/dL", grade: "B+", gradeColor: "#F97316" },
  { label: "HbA1c", value: "5.1", unit: "%", grade: "A", gradeColor: "#22C55E" },
  { label: "ApoB", value: "82", unit: "mg/dL", grade: "A-", gradeColor: "#22C55E" },
];

const colorClasses: Record<string, string> = {
  blue: "bg-[#3B82F6]/20 text-[#3B82F6]",
  green: "bg-[#22C55E]/20 text-[#22C55E]",
  orange: "bg-[#F97316]/20 text-[#F97316]",
};
---

<section class="py-16 md:py-28 overflow-hidden bg-background relative">
  <div class="container px-4 relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-10">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-3 block">
        Your Dashboard
      </span>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        See Your Data, In Real Time
      </h2>
      <p class="text-muted-foreground">
        Every data point visualized. Every protocol personalized. Complete visibility into your transformation.
      </p>
    </div>

    <!-- Dashboard Preview Grid -->
    <div class="max-w-6xl mx-auto relative">
      <!-- Outer glow wrapper -->
      <div class="absolute -inset-4 bg-gradient-to-b from-primary/25 via-primary/15 to-primary/25 rounded-3xl blur-xl"></div>
      <div class="absolute -inset-8 bg-primary/8 rounded-[2rem] blur-[60px]"></div>
    <div class="relative space-y-4 p-4 md:p-6 rounded-2xl bg-[#1a1525]/80 border border-primary/20">
      <!-- Top Row -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <!-- Welcome Card -->
        <div class="lg:col-span-2 p-5 bg-card rounded-2xl border border-primary/15 shadow-[0_0_15px_hsl(261_27%_48%/0.08)]">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
            <div>
              <p class="text-muted-foreground text-sm">Welcome back</p>
              <h3 class="text-xl font-bold text-foreground">Your Dashboard</h3>
            </div>
            <div class="flex gap-2 flex-wrap">
              {metricBadges.map((badge) => (
                <div class={`flex items-center gap-2 px-3 py-2 rounded-lg ${colorClasses[badge.color]}`}>
                  <span class="font-bold">{badge.value}</span>
                  <span class="text-xs opacity-70">{badge.label}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            {statBoxes.map((stat) => (
              <div class="p-3 rounded-xl bg-background border border-border">
                <p class="text-xs text-muted-foreground mb-1">{stat.label}</p>
                <div class="flex items-baseline gap-1">
                  <span class="text-lg font-bold text-foreground">{stat.value}</span>
                  <span class="text-xs text-muted-foreground">{stat.unit}</span>
                </div>
                {stat.trend && (
                  <p class={`text-xs mt-1 ${stat.trendColor === 'green' ? 'text-[#22C55E]' : 'text-[#EF4444]'}`}>
                    {stat.trend} this week
                  </p>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- Health Score Card -->
        <div class="p-5 bg-card rounded-2xl border border-primary/15 shadow-[0_0_15px_hsl(261_27%_48%/0.08)]">
          <h4 class="text-sm font-medium text-muted-foreground mb-3">Biomarker Health Score</h4>
          <div class="flex items-center justify-center">
            <div class="relative w-28 h-28">
              <svg class="w-full h-full transform -rotate-90">
                <circle cx="56" cy="56" r="48" fill="none" stroke="hsl(var(--muted))" stroke-width="10" />
                <circle cx="56" cy="56" r="48" fill="none" stroke="#22C55E" stroke-width="10" stroke-dasharray={`${84 * 3.02} ${100 * 3.02}`} stroke-linecap="round" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-2xl font-bold text-foreground">84</span>
                <span class="text-xs text-muted-foreground">/100</span>
              </div>
            </div>
          </div>
          <p class="text-center text-sm text-muted-foreground mt-3">
            <span class="text-[#22C55E] font-medium">Optimized</span> range
          </p>
        </div>
      </div>

      <!-- Middle Row - Strategy Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {strategies.map((s) => (
          <div class="p-5 bg-card rounded-2xl border border-primary/15 shadow-[0_0_15px_hsl(261_27%_48%/0.08)] border-l-4" style={`border-left-color: ${s.color}`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center" style={`background-color: ${s.color}20; color: ${s.color}`}>
                {s.icon === "apple" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/><path d="M10 2c1 .5 2 2 2 5"/></svg>
                )}
                {s.icon === "dumbbell" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.4 14.4 9.6 9.6"/><path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767 1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l-1.768 1.767a2 2 0 1 1 2.828 2.829z"/><path d="m21.5 21.5-1.4-1.4"/><path d="M3.9 3.9 2.5 2.5"/><path d="M6.404 12.768a2 2 0 1 1-2.829-2.829l1.768-1.767a2 2 0 1 1-2.828-2.829l2.828-2.828a2 2 0 1 1 2.829 2.828l1.767-1.768a2 2 0 1 1 2.829 2.829z"/></svg>
                )}
                {s.icon === "moon" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
                )}
              </div>
              <div>
                <h4 class="font-bold text-foreground text-sm">{s.title}</h4>
                <p class="text-xs" style={`color: ${s.color}`}>{s.status}</p>
              </div>
            </div>
            <div class="mb-3">
              <div class="flex justify-between text-xs text-muted-foreground mb-1">
                <span>Progress</span>
                <span>{s.progress}%</span>
              </div>
              <div class="h-2 bg-muted rounded-full overflow-hidden">
                <div class="h-full rounded-full" style={`width: ${s.progress}%; background-color: ${s.color}`}></div>
              </div>
            </div>
            <div class="space-y-1.5">
              {s.metrics.map((m) => (
                <div class="flex justify-between text-sm">
                  <span class="text-muted-foreground text-xs">{m.label}</span>
                  <span class="font-medium text-foreground text-xs">{m.value}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Bottom Row -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <!-- Energy Balance -->
        <div class="p-5 bg-card rounded-2xl border border-primary/15 shadow-[0_0_15px_hsl(261_27%_48%/0.08)]">
          <div class="flex items-center justify-between mb-4">
            <h4 class="text-sm font-medium text-muted-foreground">Energy Balance</h4>
            <span class="text-xs text-muted-foreground">Last 7 days</span>
          </div>
          <div class="space-y-3">
            <div>
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-muted-foreground text-xs">Intake</span>
                <span class="font-medium text-foreground text-xs">1,740 cal</span>
              </div>
              <div class="h-2.5 bg-muted rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: 83%; background-color: #22C55E"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1.5">
                <span class="text-muted-foreground text-xs">TDEE</span>
                <span class="font-medium text-foreground text-xs">2,100 cal</span>
              </div>
              <div class="h-2.5 bg-muted rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: 88%; background-color: #F97316"></div>
              </div>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-border">
            <div class="flex justify-between items-center">
              <span class="text-sm text-muted-foreground">Daily Deficit</span>
              <span class="text-lg font-bold text-[#22C55E]">-350 cal</span>
            </div>
            <p class="text-xs text-muted-foreground mt-1">On track for 0.5-1 lb/week fat loss</p>
          </div>
        </div>

        <!-- Biomarker Highlights -->
        <div class="p-5 bg-card rounded-2xl border border-primary/15 shadow-[0_0_15px_hsl(261_27%_48%/0.08)]">
          <div class="flex items-center justify-between mb-4">
            <h4 class="text-sm font-medium text-muted-foreground">Biomarker Highlights</h4>
            <span class="text-xs px-2 py-1 rounded-full bg-[#22C55E]/20 text-[#22C55E]">55 analyzed</span>
          </div>
          <div class="grid grid-cols-2 gap-3">
            {biomarkers.map((b) => (
              <div class="p-3 rounded-xl bg-background border border-border relative">
                <span class="absolute top-2 right-2 text-xs font-bold px-2 py-0.5 rounded" style={`background-color: ${b.gradeColor}20; color: ${b.gradeColor}`}>
                  {b.grade}
                </span>
                <p class="text-xs text-muted-foreground mb-1">{b.label}</p>
                <div class="flex items-baseline gap-1">
                  <span class="text-base font-bold text-foreground">{b.value}</span>
                  <span class="text-xs text-muted-foreground">{b.unit}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
    </div>
  </div>
</section>
