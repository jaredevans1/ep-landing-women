---
const BOOKING_URL = "https://cal.com/emily-evans-performance/precision-health-consult";

---

<section class="py-20 md:py-32 bg-background relative overflow-hidden">
  <!-- Top gradient line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent"></div>
  <!-- Center glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] bg-primary/15 rounded-full blur-[140px]"></div>

  <div class="container px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Headline -->
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Your Biology Is the Blueprint.<br />
        <span class="text-gradient">We Build From There.</span>
      </h2>

      <p class="text-base sm:text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto mb-4">
        55 biomarkers. Four integrated protocols. One system built from your data.
        This is how high-performing women take control of their health, body composition, and longevity.
      </p>

      <p class="text-base sm:text-lg md:text-xl text-foreground/80 font-medium max-w-2xl mx-auto mb-10">
        Start with a Precision Health Consult and get your roadmap.
      </p>

      <!-- Urgency pill -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/30 mb-8">
        <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <span class="text-sm font-medium text-primary">Limited to 5 consults per week</span>
      </div>

      <!-- CTA Button -->
      <div class="flex justify-center">
        <a
          href={BOOKING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center text-base sm:text-lg px-6 sm:px-10 h-16 bg-transparent border-2 border-primary/50 text-foreground rounded-lg font-medium hover:bg-primary hover:border-primary hover:text-white hover:shadow-[0_0_20px_hsl(261_27%_48%/0.4)] hover:scale-[1.02] transition-all duration-300 btn-glow-pulse"
        >
          Book Your Free Consult
          <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
