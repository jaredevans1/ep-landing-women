---
---

<section class="py-10 md:py-16 bg-card">
  <div class="container px-4">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-8">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase mb-3 block">
        See The System
      </span>
      <h2 class="text-3xl md:text-4xl font-bold mb-3">
        Watch How It Works
      </h2>
      <p class="text-muted-foreground">
        See exactly how we help executives transform their health.
      </p>
    </div>

    <!-- Video Container -->
    <div class="max-w-4xl mx-auto">
      <div class="relative rounded-2xl overflow-hidden border border-border shadow-card bg-background">
        <style>
          wistia-player[media-id='tbt45z0ewh']:not(:defined) {
            background: center / contain no-repeat url('https://fast.wistia.com/embed/medias/tbt45z0ewh/swatch');
            display: block;
            filter: blur(5px);
            padding-top: 55.83%;
          }
        </style>
        <wistia-player media-id="tbt45z0ewh" aspect="1.791044776119403"></wistia-player>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Lazy-load Wistia scripts only when video section is near viewport
  (function() {
    var loaded = false;
    function loadWistia() {
      if (loaded) return;
      loaded = true;
      var s1 = document.createElement('script');
      s1.src = 'https://fast.wistia.com/player.js';
      s1.async = true;
      document.head.appendChild(s1);
      var s2 = document.createElement('script');
      s2.src = 'https://fast.wistia.com/embed/tbt45z0ewh.js';
      s2.async = true;
      s2.type = 'module';
      document.head.appendChild(s2);
    }
    if ('IntersectionObserver' in window) {
      var el = document.querySelector('wistia-player');
      if (el) {
        var obs = new IntersectionObserver(function(entries) {
          if (entries[0].isIntersecting) { loadWistia(); obs.disconnect(); }
        }, { rootMargin: '200px' });
        obs.observe(el);
      }
    } else {
      loadWistia();
    }
  })();
</script>
